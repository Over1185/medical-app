{
  "name": "medical-app",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "test": "vitest",
    "test:frontend": "vitest run __test__/frontend/*.test.tsx",
    "test:backend": "vitest run __test__/backend/*.test.ts",
    "db:schema": "turso db shell ${TURSO_DB_NAME:-medical-app-citas} < db/schema.sql",
    "db:seed": "turso db shell ${TURSO_DB_NAME:-medical-app-citas} < db/seed.sql",
    "db:reset": "pnpm db:schema && pnpm db:seed",
    "lint": "biome check",
    "format": "biome format --write"
  },
  "dependencies": {
    "@libsql/client": "0.17.2",
    "@tabler/icons-react": "3.41.1",
    "next": "16.2.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sonner": "2.0.7",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.8",
    "@tailwindcss/postcss": "4.2.2",
    "@testing-library/dom": "10.4.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "25.5.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "jsdom": "29.0.1",
    "tailwindcss": "4.2.2",
    "typescript": "6.0.2",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "4.1.1"
  }
}