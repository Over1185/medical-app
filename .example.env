## Variables de entorno para el backend obligatorias
ALLOWED_ORIGINS=http://localhost:8080
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
TURSO_DATABASE_URL=libsql://your-domain.turso.io
TURSO_AUTH_TOKEN=YOUR_AUTH_TOKEN_HERE

## Variables de entorno para el backend opcionales
TURSO_DB_NAME=your-db-name